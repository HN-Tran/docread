# Copy to .env — Docker Compose loads it for variable substitution.
# See docs/inference-providers.md, docs/docker-pytorch.md, docs/llamacpp-docker-glm-ocr.md

# --- docread app (docker compose up) ---

# UI language: en (default) | de
APP_LOCALE=en

# --- Outbound request safety (SSRF guard) ---
# The compare engines (plain-text / self-peer / Azure), /api/peer-models, and the
# analyze "urlSource" input fetch a caller-supplied URL server-side. By default
# only public addresses are allowed; loopback/private/link-local/internal targets
# are blocked. Opt in to internal targets when you genuinely need them:
# Comma-separated trusted hostnames and/or CIDRs (e.g. localhost,172.17.0.0/16):
# OUTBOUND_ALLOW_HOSTS=
# Blunt escape hatch: allow ANY private/internal address (single-user/local only):
# OUTBOUND_ALLOW_PRIVATE=false
# Cap the size of a server-fetched response (bytes, 0 disables). Default 64 MiB:
# OUTBOUND_MAX_RESPONSE_BYTES=67108864

# Straighten skewed/rotated pages before OCR (default: true). Set false to skip.
# DESKEW_ENABLED=true
# Page quarter-turn before layout (content-bbox probe on scans with margins). Default: true.
# Set false only if layout already runs on upright pages; large regions skip extra rotation.
# DESKEW_PAGE_CARDINAL=false
# Tesseract OSD on content probe (same family as paperless-ngx / OCRmyPDF). Needs tesseract in image.
# DESKEW_OSD=1
# DESKEW_OSD_MIN_CONFIDENCE=1.0
# Non-OSD 180° flips are opt-in; leave off to avoid false positives on upright pages/crops.
# DESKEW_HEURISTIC_180=0
# Max dimension for fine skew detection (default 2400; higher preserves ~5° tilt on large scans).
# DESKEW_FINE_SCAN_DIM=2400
# Log deskew decisions to container logs and OCR warnings (UI Notes).
# DESKEW_DEBUG=1
# Use ink-bbox orientation when content covers less than this fraction of the page (default 0.72).
# DESKEW_CONTENT_BBOX_MAX_FILL=0.72

# Ollama on the host (default)
INFERENCE_PROVIDER=ollama
# INFERENCE_BASE_URL=
# INFERENCE_MODEL=
OLLAMA_BASE_URL=http://172.17.0.1:11434
OLLAMA_MODEL=glm-ocr:latest

# llama.cpp GLM-OCR on the host (Vulkan/ROCm/CUDA compose on :8080)
# INFERENCE_PROVIDER=openai_compatible
# INFERENCE_BASE_URL=http://host.docker.internal:8080/v1
# INFERENCE_MODEL=GLM-OCR-Q8_0.gguf
# INFERENCE_VISION_MODELS=GLM-OCR-Q8_0.gguf
# INFERENCE_VISION_PROBE=false

# --- GPU layout (optional compose overrides, see docs/docker-pytorch.md) ---
# CPU (default):  docker compose up --build
# NVIDIA:         docker compose -f docker-compose.yml -f docker-compose.cuda.yml up --build
# AMD ROCm:       docker compose -f docker-compose.yml -f docker-compose.rocm.yml up --build
# docread + llama.cpp stack: docker compose -f docker-compose.stack.yml up --build

# --- llama.cpp only (docker compose -f docker-compose.llamacpp.yml up) ---

# LLAMACPP_PORT=8080
# LLAMACPP_HF_REPO=ggml-org/GLM-OCR-GGUF
